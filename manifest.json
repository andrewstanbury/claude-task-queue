{
  "name": "claude-task-queue",
  "version": "0.2.0",
  "description": "Zero-token, read-only viewer for Claude Code's native task list — aggregates tasks across all sessions/projects and renders to-do/doing/done on the status line.",
  "homepage": "https://github.com/andrewstanbury/claude-task-queue",
  "license": "MIT",
  "author": "Andrew Stanbury",
  "statusLine": "bin/tq-status.sh",
  "bin": {
    "tq": "bin/tq",
    "tq-status": "bin/tq-status.sh"
  },
  "reads": "~/.claude/tasks (Claude Code's native task store) + ~/.claude/projects (session→project mapping)",
  "state_dir": "~/.claude/state/task-queue (project-label cache only)",
  "env_overrides": [
    "CLAUDE_TQ_TASKS_DIR",
    "CLAUDE_TQ_PROJECTS_DIR",
    "CLAUDE_TQ_STATE_DIR"
  ],
  "requires": {
    "bash": ">=4",
    "jq": "any"
  }
}
