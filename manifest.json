{
  "name": "claude-task-queue",
  "version": "0.1.0",
  "description": "Durable, project-scoped task queue for Claude Code with prompt auto-decomposition (Haiku triage), Wi-Fi-warm ordering, and pause-resumable autopilot.",
  "homepage": "https://github.com/andrewstanbury/claude-task-queue",
  "license": "MIT",
  "author": "Andrew Stanbury",
  "hooks": {
    "UserPromptSubmit": "bin/tq-decompose.sh",
    "PreToolUse": "bin/tq-pretool.sh"
  },
  "bin": {
    "tq": "bin/tq",
    "tq-status": "bin/tq-status.sh"
  },
  "state_dir": "~/.claude/state/task-queue",
  "env_overrides": [
    "CLAUDE_TQ_DISABLED",
    "CLAUDE_TQ_PRETOOL_DISABLED",
    "CLAUDE_TQ_HAIKU_DISABLED",
    "CLAUDE_TQ_STATE_DIR"
  ],
  "requires": {
    "bash": ">=4",
    "jq": "any",
    "sha1sum": "any"
  }
}
