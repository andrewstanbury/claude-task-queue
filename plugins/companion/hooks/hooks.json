{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/session-start.sh\"" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/prompt.sh\"" } ] }
    ],
    "PreToolUse": [
      { "matcher": "Write|Edit", "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/secret-guard.sh\"" },
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/work-guard.sh\"" }
      ] },
      { "matcher": "AskUserQuestion", "hooks": [ { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/ask-guard.sh\"" } ] }
    ],
    "PostToolUse": [
      { "matcher": "Write|Edit", "hooks": [
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/touch.sh\"" },
        { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/intent-note.sh\"" }
      ] }
    ],
    "Stop": [
      { "hooks": [ { "type": "command", "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/stop-autopilot.sh\"" } ] }
    ]
  }
}
