#!/usr/bin/env bash
# tq — read-only viewer for Claude Code's native task list.
#
# The model owns the tasks (it creates/updates them via its native task tools
# as it works). This CLI only READS them, so it never spends tokens and never
# desyncs from what the model sees.
#
#   tq            full grouped to-do/doing/done table (alias of `tq list`)
#   tq list       same
#   tq status     one-line summary of open work across all projects
#   tq path       print the native tasks directory being read
#   tq help       this help

set -euo pipefail

SELF="${BASH_SOURCE[0]}"
while [ -L "$SELF" ]; do
  link="$(readlink "$SELF")"
  case "$link" in
    /*) SELF="$link" ;;
    *)  SELF="$(dirname "$SELF")/$link" ;;
  esac
done
THIS_DIR="$(cd "$(dirname "$SELF")" && pwd)"
PLUGIN_DIR="$(cd "$THIS_DIR/.." && pwd)"
# shellcheck source=../lib/tasks.sh
. "$PLUGIN_DIR/lib/tasks.sh"

usage() {
  sed -n '2,12p' "$SELF" | sed 's/^# \{0,1\}//'
}

cmd="${1:-list}"
case "$cmd" in
  list|"")     tq_list_table ;;
  status)      tq_status_line ;;
  path)        printf '%s\n' "$(tq_tasks_dir)" ;;
  help|-h|--help) usage ;;
  *)
    printf 'tq: unknown command %q\n\n' "$cmd" >&2
    usage >&2
    exit 64
    ;;
esac
